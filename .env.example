# ── PostgreSQL ──────────────────────────────
# Local (Docker): localhost | Serveur Plesk: localhost (car meme serveur)
DB_HOST=localhost
DB_PORT=5432
DB_USER=saas_dev
DB_PASSWORD=saas_dev_password
DB_NAME=saas_crm

# ── JWT ─────────────────────────────────────
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_use_a_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Encryption (cles API CRM) ──────────────
# Generer avec: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_MASTER_KEY=CHANGE_ME_generate_64_hex_chars

# ── Ollama ──────────────────────────────────
# Local (Docker): http://ollama:11434 | Serveur distant: https://ollama.lescommunicateurs.ca
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b-instruct-q4_K_M

# ── ElevenLabs (TTS vocal) ──────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_voice_id

# ── Server ──────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Backend URL (pour le frontend en dev distant) ────────
# Si le backend est sur le serveur Plesk, mettre l'URL complete
# BACKEND_URL=https://crm-api.lescommunicateurs.ca
